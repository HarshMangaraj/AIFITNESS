{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth"
    },
    {
      "source": "/api/food/(.*)",
      "destination": "/api/food"
    },
    {
      "source": "/api/healthz",
      "destination": "/api/health"
    },
    {
      "source": "/api/progress/(.*)",
      "destination": "/api/progress"
    },
    {
      "source": "/api/workout/(.*)",
      "destination": "/api/workout"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ],
  "outputDirectory": "frontend/dist"
}
