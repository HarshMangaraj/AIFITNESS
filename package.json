{
  "name": "ai-fitness-coach",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node dev.js",
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "typecheck": "npm run typecheck --prefix backend && npm run typecheck --prefix frontend",
    "clean": "Remove-Item -Path node_modules, backend/node_modules, frontend/node_modules -Recurse -Force -ErrorAction SilentlyContinue"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3",
    "@types/express": "^5",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2",
    "dotenv": "^16.4.5",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9",
    "prisma": "^7.6.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
